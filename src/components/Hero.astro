---
/**
 * Hero plein écran (page d'arrivée) : photo de la façade en fond, logo, titre,
 * statut « Ouvert / Fermé » en direct et actions. Reste le HAUT de la page
 * unique (le bouton descend vers les sections) — pas une page-portail séparée,
 * pour préserver le référencement.
 */
import { Image } from 'astro:assets';
import facade from '../assets/facade-pharmacie.png';
import { hero, pharmacie, horaires, horairesNote, lienItineraire, logo } from '../data/site';
import Icone from './Icone.astro';

// Met les deux derniers mots du titre en accent doré italique (« avec soin »).
const motsTitre = hero.titre.trim().split(/\s+/);
const titreAccent = motsTitre.slice(-2).join(' ');
const titreDebut = motsTitre.slice(0, -2).join(' ');
---

<section class="hero" id="accueil">
  <Image
    src={facade}
    alt={`Façade et vitrines de la ${pharmacie.nom}`}
    class="hero__bg"
    widths={[640, 1024, 1400, 1659]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
  />
  <!-- Dégradé sombre (bleu marine) ancré en bas : lisibilité du texte. -->
  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="conteneur hero__inner">
    <!-- Logo emblème dans un médaillon givré à liseré doré. -->
    <div class="hero__logo">
      <img
        src={logo.srcTransparent}
        alt={`Logo ${pharmacie.nom}`}
        width={logo.largeurTransparent}
        height={logo.hauteurTransparent}
        decoding="async"
      />
    </div>

    <div class="hero__contenu">
      <h1 class="hero__titre">
        {titreDebut}<br /><span class="hero__titre-accent">{titreAccent}.</span>
      </h1>

      <a href="#services" class="hero__cta">
        <span>Découvrir nos services</span>
        <Icone nom="chevron-droit" taille={20} class="hero__cta-fleche" />
      </a>

      <!-- Accès rapides : icône dorée cerclée + label. -->
      <div class="hero__acces">
        <a
          href={`tel:${pharmacie.telephone.lien}`}
          class="hero__acces-item"
          aria-label={`Appeler la ${pharmacie.nom} au ${pharmacie.telephone.affichage}`}
        >
          <span class="hero__acces-ico"><Icone nom="phone" taille={17} /></span>
          <span>Appeler</span>
        </a>
        <span class="hero__acces-sep" aria-hidden="true"></span>
        <a
          href={lienItineraire}
          target="_blank"
          rel="noopener"
          class="hero__acces-item"
          aria-label={`Itinéraire vers la ${pharmacie.nom}`}
        >
          <span class="hero__acces-ico"><Icone nom="pin" taille={17} /></span>
          <span>Itinéraire</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Statut d'ouverture, pastille flottante (→ ouvre la popup des horaires). -->
  <button class="hero__statut" data-hero-statut type="button">
    <span class="hero__statut-dot" aria-hidden="true"></span>
    <strong class="hero__statut-etat" data-statut-etat>{hero.ouverture}</strong>
    <span class="hero__statut-detail" data-statut-detail></span>
  </button>
</section>

<!-- Popup des horaires (dialog natif, ouvert au clic sur le statut). -->
<dialog class="modal-horaires" data-horaires-modal aria-label="Horaires d'ouverture">
  <div class="modal-horaires__inner">
    <button class="modal-horaires__close" data-close type="button" aria-label="Fermer">
      <Icone nom="close" taille={20} />
    </button>
    <h2 class="modal-horaires__titre">Horaires d'ouverture</h2>
    <dl class="modal-horaires__jours">
      {horaires.map((c) => (
        <div class:list={['modal-horaires__jour', { 'est-ferme': c.ferme }]}>
          <dt>{c.jour}</dt>
          <dd>{c.heures}</dd>
        </div>
      ))}
    </dl>
    <p class="modal-horaires__note">{horairesNote}</p>
    <p class="modal-horaires__garde">
      <Icone nom="shield" taille={18} />
      <span>Pharmacie de garde : <strong>{pharmacie.garde}</strong> (24h/24)</span>
    </p>
  </div>
</dialog>

<!-- Statut Ouvert / Fermé en direct + ouverture de la popup horaires. -->
<script define:vars={{ horaires }}>
  (function () {
    const el = document.querySelector('[data-hero-statut]');
    if (!el) return;

    const parse = (str) => {
      if (!str) return [];
      const t = [...str.matchAll(/(\d{1,2})\s*[h:]\s*(\d{0,2})/g)].map(
        (m) => parseInt(m[1], 10) * 60 + (m[2] ? parseInt(m[2], 10) : 0)
      );
      const r = [];
      for (let i = 0; i + 1 < t.length; i += 2) r.push([t[i], t[i + 1]]);
      return r;
    };

    const now = new Date();
    const dayIdx = (now.getDay() + 6) % 7;
    const mins = now.getHours() * 60 + now.getMinutes();
    const today = horaires[dayIdx];
    const ranges = today && !today.ferme ? parse(today.heures) : [];
    const open = ranges.some(([o, c]) => mins >= o && mins < c);

    el.classList.add(open ? 'is-open' : 'is-closed');
    el.querySelector('[data-statut-etat]').textContent = open ? 'Ouvert' : 'Fermé';

    // Formate des minutes en « 8h30 » (ou « 19h » si les minutes sont nulles).
    const fmt = (m) => {
      const h = Math.floor(m / 60);
      const mm = m % 60;
      return mm === 0 ? `${h}h` : `${h}h${String(mm).padStart(2, '0')}`;
    };

    // Détail le plus utile selon le statut : heure de fermeture si ouvert,
    // prochaine ouverture (aujourd'hui ou un autre jour) si fermé.
    const detail = el.querySelector('[data-statut-detail]');
    if (detail) {
      let texte = '';
      if (open) {
        const enCours = ranges.find(([o, c]) => mins >= o && mins < c);
        texte = `ferme à ${fmt(enCours[1])}`;
      } else {
        const prochaine = ranges.find(([o]) => mins < o);
        if (prochaine) {
          texte = `ouvre à ${fmt(prochaine[0])}`;
        } else {
          for (let i = 1; i <= 7; i++) {
            const j = horaires[(dayIdx + i) % 7];
            const r = j && !j.ferme ? parse(j.heures) : [];
            if (r.length) {
              texte = `ouvre ${j.jour.toLowerCase()} à ${fmt(r[0][0])}`;
              break;
            }
          }
        }
      }
      detail.textContent = texte ? `· ${texte}` : '';
    }

    // Ouverture / fermeture de la popup des horaires.
    const modal = document.querySelector('[data-horaires-modal]');
    if (modal) {
      el.addEventListener('click', () => modal.showModal());
      const closeBtn = modal.querySelector('[data-close]');
      if (closeBtn) closeBtn.addEventListener('click', () => modal.close());
      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.close();
      });
    }
  })();
</script>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    border-bottom: 1px solid var(--bordure);
  }

  /* Photo de fond, plein cadre. */
  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: -3;
  }
  /* Dégradé sombre (bleu marine) : quasi clair en haut, presque opaque en
     bas où se pose le texte. Léger renfort à gauche. Spec de la maquette. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(
        180deg,
        rgba(4, 16, 31, 0.14) 0%,
        rgba(4, 16, 31, 0.1) 25%,
        rgba(4, 16, 31, 0.55) 62%,
        rgba(4, 16, 31, 0.96) 100%
      ),
      linear-gradient(90deg, rgba(4, 16, 31, 0.22) 0%, transparent 55%),
      /* Vignette douce : assombrit les bords, la photo se fond mieux dans la page. */
      radial-gradient(120% 95% at 50% 42%, transparent 55%, rgba(2, 10, 22, 0.32) 100%);
  }

  /* Layout mobile : colonne, logo en haut / contenu en bas. */
  .hero__inner {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--esp-xl);
    min-height: 100svh;
    padding-block: clamp(4.5rem, 11vh, 6.5rem) clamp(1.75rem, 5vh, 2.75rem);
  }

  /* Médaillon logo : carré organique presque carré (1/1.08), verre blanc
     chaud, double contour doré, reflet subtil. Valeurs exactes fournies. */
  .hero__logo {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(58vw, 250px);
    aspect-ratio: 1 / 1.08;
    margin: 18px auto 0;
    padding: 13px 10px;
    overflow: hidden;
    border-radius: 34%;
    /* Transparent mais plus blanc, et net (peu de flou) : la photo derrière
       reste nette au lieu d'être brouillée. */
    background: linear-gradient(
      145deg,
      rgba(255, 255, 255, 0.34) 0%,
      rgba(250, 245, 236, 0.28) 55%,
      rgba(235, 225, 211, 0.24) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.55);
    box-shadow:
      0 24px 55px rgba(4, 18, 35, 0.24),
      0 8px 18px rgba(4, 18, 35, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(4px) saturate(115%);
    animation: apparition 0.7s ease both;
  }
  /* Double contour intérieur doré. */
  .hero__logo::before {
    content: '';
    position: absolute;
    inset: 6px;
    border-radius: calc(34% - 4px);
    border: 1px solid rgba(205, 158, 79, 0.62);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.55), 0 0 18px rgba(205, 158, 79, 0.08);
    pointer-events: none;
  }
  /* Reflet subtil en haut. */
  .hero__logo::after {
    content: '';
    position: absolute;
    top: 10%;
    left: 15%;
    width: 70%;
    height: 36%;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.28);
    filter: blur(26px);
    pointer-events: none;
  }
  .hero__logo img {
    position: relative;
    z-index: 2;
    display: block;
    width: 98%;
    max-width: 245px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 7px 14px rgba(8, 30, 55, 0.09));
  }
  @media (max-width: 480px) {
    .hero__logo {
      width: 58vw;
      max-width: 245px;
      min-width: 195px;
      aspect-ratio: 1 / 1.08;
      padding: 12px 9px;
      border-radius: 34%;
    }
    .hero__logo img {
      width: 90%;
    }
  }

  .hero__contenu {
    width: 100%;
    max-width: 34rem;
    margin: 0 auto;
    text-align: center;
    color: var(--blanc);
  }
  .hero__contenu > * {
    animation: apparition 0.7s ease both;
  }
  .hero__contenu > *:nth-child(2) { animation-delay: 0.08s; }
  .hero__contenu > *:nth-child(3) { animation-delay: 0.16s; }
  @keyframes apparition {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: none; }
  }

  /* Titre sans-serif serré (DM Sans), accent « avec soin » en serif italique. */
  .hero__titre {
    margin: 0;
    font-family: 'DM Sans Variable', 'Inter Variable', system-ui, sans-serif;
    font-size: clamp(2.5rem, 1rem + 7vw, 5.5rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.045em;
    color: var(--blanc);
    text-wrap: balance;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.35), 0 1px 4px rgba(0, 0, 0, 0.45);
  }
  .hero__titre-accent {
    display: inline-block;
    margin-top: 0.5rem;
    font-family: 'Instrument Serif', Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.13em;
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--accent-or);
  }

  /* CTA : fond marine + liseré doré + flèche dorée, centré. */
  .hero__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    max-width: 30rem;
    margin-top: clamp(1.5rem, 4vh, 2rem);
    margin-inline: auto;
    padding: 1.05rem 1.25rem;
    font-family: var(--police-titre);
    font-size: var(--taille-base);
    font-weight: var(--graisse-medium);
    color: var(--blanc);
    text-decoration: none;
    background: linear-gradient(135deg, rgba(16, 38, 64, 0.96), rgba(7, 24, 46, 0.96));
    border: 1px solid rgba(216, 170, 85, 0.62);
    border-radius: 15px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.2);
    transition: transform var(--transition-douce), border-color var(--transition-douce),
      box-shadow var(--transition-douce);
  }
  .hero__cta-fleche {
    color: var(--accent-or);
    flex: none;
    transition: transform var(--transition-douce);
  }
  .hero__cta:hover {
    transform: translateY(-2px);
    border-color: var(--accent-or);
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.26);
  }
  .hero__cta:hover .hero__cta-fleche {
    transform: translateX(4px);
  }

  /* Accès rapides : icône dorée + label, séparateur fin. */
  .hero__acces {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1.25rem, 5vw, 1.5rem);
    margin-top: clamp(1rem, 3vh, 1.4rem);
  }
  .hero__acces-sep {
    width: 1px;
    height: 1.5rem;
    background: rgba(255, 255, 255, 0.24);
  }
  .hero__acces-item {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.9);
    font-family: var(--police-titre);
    font-weight: var(--graisse-medium);
    font-size: var(--taille-sm);
    transition: color var(--transition-douce);
  }
  /* Icône dorée dans un anneau doré fin. */
  .hero__acces-ico {
    display: grid;
    place-items: center;
    width: 2.15rem;
    height: 2.15rem;
    border-radius: 50%;
    border: 1px solid rgba(216, 170, 85, 0.55);
    color: var(--accent-or);
    transition: border-color var(--transition-douce), background-color var(--transition-douce);
  }
  .hero__acces-item:hover {
    color: var(--accent-or);
  }
  .hero__acces-item:hover .hero__acces-ico {
    border-color: var(--accent-or);
    background: rgba(216, 170, 85, 0.12);
  }

  /* Statut « Ouvert / Fermé », pastille flottante en verre marine. */
  .hero__statut {
    position: fixed;
    top: 18px;
    right: 18px;
    z-index: 200;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 42px;
    margin: 0;
    padding: 10px 17px;
    background: rgba(7, 24, 46, 0.78);
    backdrop-filter: saturate(160%) blur(18px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--rayon-pilule);
    font-family: var(--police-titre);
    font-size: 13px;
    color: rgba(255, 255, 255, 0.72);
    box-shadow: 0 12px 30px rgba(4, 16, 31, 0.15);
    cursor: pointer;
  }
  .hero__statut-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #d7a352;
    box-shadow: 0 0 0 4px rgba(215, 163, 82, 0.14);
    flex: none;
  }
  .hero__statut-etat {
    color: var(--blanc);
    font-weight: 600;
    white-space: nowrap;
  }
  .hero__statut-detail {
    white-space: nowrap;
  }
  .hero__statut.is-open .hero__statut-dot {
    background: #4cda82;
    box-shadow: 0 0 0 4px rgba(76, 218, 130, 0.12);
  }

  /* Desktop : 2 colonnes (logo à gauche, texte à droite). */
  @media (min-width: 900px) {
    .hero__inner {
      display: grid;
      grid-template-columns: minmax(320px, 0.92fr) minmax(420px, 1.08fr);
      align-items: center;
      justify-content: center;
      gap: clamp(3rem, 6vw, 5rem);
      padding-block: clamp(6rem, 12vh, 8rem) clamp(3rem, 8vh, 5rem);
    }
    .hero__logo {
      width: clamp(280px, 24vw, 360px);
      margin: 0;
    }
    .hero__logo img {
      max-width: 335px;
    }
    .hero__contenu {
      margin: 0;
      max-width: none;
      text-align: left;
    }
    .hero__cta,
    .hero__acces {
      max-width: 30rem;
    }
    .hero__cta {
      margin-inline: 0;
    }
    .hero__acces {
      justify-content: flex-start;
    }
  }

  @media (max-width: 760px) {
    .hero__bg {
      object-position: 46% center;
    }
  }
  @media (max-width: 370px) {
    .hero__titre {
      font-size: 2.3rem;
    }
  }

  /* --- Popup des horaires (dialog) --- */
  .modal-horaires {
    margin: auto;
    width: calc(100% - 2rem);
    max-width: 26rem;
    padding: 0;
    border: none;
    border-radius: var(--rayon-lg);
    box-shadow: var(--ombre-lg);
    color: var(--couleur-texte);
    background: var(--blanc);
  }
  .modal-horaires::backdrop {
    background: rgba(10, 46, 92, 0.45);
    backdrop-filter: blur(2px);
  }
  .modal-horaires__inner {
    position: relative;
    padding: var(--esp-xl) var(--esp-lg) var(--esp-lg);
  }
  .modal-horaires__close {
    position: absolute;
    top: var(--esp-sm);
    right: var(--esp-sm);
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border: none;
    border-radius: 50%;
    background: var(--bleu-clair-1);
    color: var(--bleu-profond);
    cursor: pointer;
    transition: background-color var(--transition-douce);
  }
  .modal-horaires__close:hover {
    background: var(--bleu-clair-3);
  }
  .modal-horaires__titre {
    font-size: var(--taille-md);
    margin-bottom: var(--esp-md);
  }
  .modal-horaires__jours {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--bordure);
    border-radius: var(--rayon-md);
    overflow: hidden;
  }
  .modal-horaires__jour {
    display: flex;
    justify-content: space-between;
    gap: var(--esp-md);
    padding: 0.6rem var(--esp-md);
  }
  .modal-horaires__jour + .modal-horaires__jour {
    border-top: 1px solid var(--bleu-clair-2);
  }
  .modal-horaires__jour dt {
    font-weight: var(--graisse-medium);
  }
  .modal-horaires__jour dd {
    color: var(--couleur-texte-doux);
    font-size: var(--taille-sm);
  }
  .modal-horaires__jour.est-ferme dd {
    color: var(--slate-2);
  }
  .modal-horaires__note {
    margin-top: var(--esp-sm);
    font-size: var(--taille-sm);
    color: var(--couleur-texte-doux);
  }
  .modal-horaires__garde {
    display: flex;
    align-items: center;
    gap: var(--esp-xs);
    margin-top: var(--esp-md);
    padding: var(--esp-sm) var(--esp-md);
    background: var(--bleu-clair-1);
    border-radius: var(--rayon-md);
    font-size: var(--taille-sm);
  }
  .modal-horaires__garde :global(svg) {
    color: var(--bleu-medium);
    flex: none;
  }
  .modal-horaires__garde strong {
    color: var(--bleu-medium);
  }
</style>
