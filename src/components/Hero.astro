---
/**
 * Hero plein écran (page d'arrivée) : photo de la façade en fond, logo, titre,
 * statut « Ouvert / Fermé » en direct et actions. Reste le HAUT de la page
 * unique (le bouton descend vers les sections) — pas une page-portail séparée,
 * pour préserver le référencement.
 */
import { Image } from 'astro:assets';
import facade from '../assets/facade-pharmacie.png';
import { hero, pharmacie, horaires, horairesNote, lienItineraire, logo } from '../data/site';
import Icone from './Icone.astro';
---

<section class="hero" id="accueil">
  <Image
    src={facade}
    alt={`Façade de la ${pharmacie.nom}, au bord de mer à Cargèse au coucher du soleil`}
    class="hero__bg"
    widths={[640, 1024, 1400, 1659]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
  />
  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="conteneur hero__inner">
    <div class="hero__contenu">
      <img
        class="hero__logo"
        src={logo.srcTransparent}
        alt={`Logo ${pharmacie.nom}`}
        width={logo.largeur}
        height={logo.hauteur}
        decoding="async"
      />

      <h1 class="hero__titre">{hero.titre}</h1>

      <!-- Trait doré décoratif, en écho au logo. -->
      <span class="hero__trait" aria-hidden="true"></span>

      <div class="hero__actions">
        <a href="#services" class="btn btn--or hero__cta">
          <span>Découvrir nos services</span>
        </a>
      </div>

      <!-- Accès rapides : cercle + label sous le bouton (sobre, plat). -->
      <div class="hero__acces">
        <a
          href={`tel:${pharmacie.telephone.lien}`}
          class="hero__acces-item"
          aria-label={`Appeler la ${pharmacie.nom} au ${pharmacie.telephone.affichage}`}
        >
          <span class="hero__acces-ico"><Icone nom="phone" taille={27} /></span>
          <span class="hero__acces-lbl">Appeler</span>
        </a>
        <span class="hero__acces-sep" aria-hidden="true"></span>
        <a
          href={lienItineraire}
          target="_blank"
          rel="noopener"
          class="hero__acces-item"
          aria-label={`Itinéraire vers la ${pharmacie.nom}`}
        >
          <span class="hero__acces-ico"><Icone nom="route" taille={27} /></span>
          <span class="hero__acces-lbl">Itinéraire</span>
        </a>
      </div>

      <!-- Statut d'ouverture, plat (bouton → ouvre la popup des horaires). -->
      <button class="hero__statut" data-hero-statut type="button">
        <span class="hero__statut-dot" aria-hidden="true"></span>
        <span class="hero__statut-date" data-statut-date></span>
        <span class="hero__statut-txt">
          <span class="hero__statut-etat" data-statut-etat>{hero.ouverture}</span>
          <span class="hero__statut-detail" data-statut-detail>Voir les horaires</span>
        </span>
        <Icone nom="chevron" taille={16} class="hero__statut-chevron" />
      </button>
    </div>
  </div>
</section>

<!-- Popup des horaires (dialog natif, ouvert au clic sur le statut). -->
<dialog class="modal-horaires" data-horaires-modal aria-label="Horaires d'ouverture">
  <div class="modal-horaires__inner">
    <button class="modal-horaires__close" data-close type="button" aria-label="Fermer">
      <Icone nom="close" taille={20} />
    </button>
    <h2 class="modal-horaires__titre">Horaires d'ouverture</h2>
    <dl class="modal-horaires__jours">
      {horaires.map((c) => (
        <div class:list={['modal-horaires__jour', { 'est-ferme': c.ferme }]}>
          <dt>{c.jour}</dt>
          <dd>{c.heures}</dd>
        </div>
      ))}
    </dl>
    <p class="modal-horaires__note">{horairesNote}</p>
    <p class="modal-horaires__garde">
      <Icone nom="shield" taille={18} />
      <span>Pharmacie de garde : <strong>{pharmacie.garde}</strong> (24h/24)</span>
    </p>
  </div>
</dialog>

<!-- Statut Ouvert / Fermé en direct + ouverture de la popup horaires. -->
<script define:vars={{ horaires }}>
  (function () {
    const el = document.querySelector('[data-hero-statut]');
    if (!el) return;

    const parse = (str) => {
      if (!str) return [];
      const t = [...str.matchAll(/(\d{1,2})\s*[h:]\s*(\d{0,2})/g)].map(
        (m) => parseInt(m[1], 10) * 60 + (m[2] ? parseInt(m[2], 10) : 0)
      );
      const r = [];
      for (let i = 0; i + 1 < t.length; i += 2) r.push([t[i], t[i + 1]]);
      return r;
    };

    const now = new Date();
    const dayIdx = (now.getDay() + 6) % 7;
    const mins = now.getHours() * 60 + now.getMinutes();
    const today = horaires[dayIdx];
    const ranges = today && !today.ferme ? parse(today.heures) : [];
    const open = ranges.some(([o, c]) => mins >= o && mins < c);

    el.classList.add(open ? 'is-open' : 'is-closed');
    el.querySelector('[data-statut-etat]').textContent = open ? 'Ouvert' : 'Fermé';

    // Détail : horaires du jour (ou « fermé aujourd'hui »).
    const detail = el.querySelector('[data-statut-detail]');
    if (detail) {
      detail.textContent = today && !today.ferme
        ? `Aujourd'hui : ${today.heures}`
        : "Fermé aujourd'hui";
    }

    // Date du jour (ex. « Dimanche 5 juillet 2026 »), affichée sur mobile.
    const dateEl = el.querySelector('[data-statut-date]');
    if (dateEl) {
      const texte = new Intl.DateTimeFormat('fr-FR', {
        weekday: 'long',
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      }).format(now);
      dateEl.textContent = texte.charAt(0).toUpperCase() + texte.slice(1);
    }

    // Ouverture / fermeture de la popup des horaires.
    const modal = document.querySelector('[data-horaires-modal]');
    if (modal) {
      el.addEventListener('click', () => modal.showModal());
      const closeBtn = modal.querySelector('[data-close]');
      if (closeBtn) closeBtn.addEventListener('click', () => modal.close());
      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.close();
      });
    }
  })();
</script>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    border-bottom: 1px solid var(--bordure);
  }

  /* Photo de fond, plein cadre. */
  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 68% center;
    z-index: -2;
  }
  /* Voile clair sur la gauche pour la lisibilité du texte. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      104deg,
      rgba(255, 255, 255, 0.8) 0%,
      rgba(255, 255, 255, 0.52) 28%,
      rgba(255, 255, 255, 0.12) 52%,
      rgba(255, 255, 255, 0) 68%
    );
  }

  /* Plein écran : contenu placé dans le haut (moins de vide au-dessus). */
  .hero__inner {
    display: flex;
    align-items: flex-start;
    min-height: 100svh;
    padding-block: clamp(4.5rem, 11vh, 7.5rem) var(--esp-2xl);
  }
  .hero__contenu {
    max-width: 36rem;
  }
  .hero__contenu > * {
    animation: apparition 0.7s ease both;
  }
  .hero__contenu > *:nth-child(2) { animation-delay: 0.08s; }
  .hero__contenu > *:nth-child(3) { animation-delay: 0.16s; }
  .hero__contenu > *:nth-child(4) { animation-delay: 0.24s; }
  .hero__contenu > *:nth-child(5) { animation-delay: 0.32s; }
  @keyframes apparition {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: none; }
  }

  /* Logo détouré, posé directement sur la photo (pas de plaque). */
  .hero__logo {
    display: block;
    width: clamp(300px, 37vw, 500px);
    height: auto;
    margin-bottom: var(--esp-lg);
    filter: drop-shadow(0 2px 10px rgba(10, 46, 92, 0.15));
  }

  .hero__titre {
    font-size: clamp(2.3rem, 1.4rem + 3.4vw, 3.9rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }
  /* Point doré final, en écho au traitement « de Cargèse » du logo. */
  .hero__titre::after {
    content: '.';
    color: var(--accent-or);
  }

  /* Trait doré décoratif sous le titre. */
  .hero__trait {
    display: block;
    width: 3.5rem;
    height: 2px;
    margin-top: var(--esp-md);
    background: var(--accent-or);
  }

  /* Statut « Ouvert / Fermé » plat : point + texte sur deux lignes. */
  .hero__statut {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: var(--esp-xl);
    padding: 0;
    background: none;
    border: none;
    box-shadow: none;
    font-family: inherit;
    color: var(--couleur-texte);
    text-align: left;
    cursor: pointer;
  }
  /* Point plein entouré d'un anneau net (plus premium qu'un halo flou). */
  .hero__statut-dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: var(--statut-ferme);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--statut-ferme) 12%, transparent);
    outline: 1.5px solid color-mix(in srgb, var(--statut-ferme) 45%, transparent);
    outline-offset: 3px;
    flex: none;
  }
  .hero__statut-txt {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .hero__statut-etat {
    font-weight: var(--graisse-forte);
    font-size: var(--taille-base);
    color: var(--statut-ferme);
  }
  .hero__statut-detail {
    font-size: var(--taille-sm);
    color: var(--couleur-texte-doux);
  }
  .hero__statut:hover .hero__statut-detail {
    color: var(--bleu-medium);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  /* Date du jour + chevron : réservés au badge compact du mobile. */
  .hero__statut-date,
  .hero__statut-chevron {
    display: none;
  }
  .hero__statut.is-open .hero__statut-dot {
    background: var(--statut-ouvert);
    outline-color: color-mix(in srgb, var(--statut-ouvert) 45%, transparent);
    animation: pouls 2.2s ease-out infinite;
  }
  .hero__statut.is-open .hero__statut-etat {
    color: var(--statut-ouvert);
  }
  @keyframes pouls {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--statut-ouvert) 55%, transparent); }
    70% { box-shadow: 0 0 0 0.5rem color-mix(in srgb, var(--statut-ouvert) 0%, transparent); }
    100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--statut-ouvert) 0%, transparent); }
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--esp-sm);
    margin-top: var(--esp-xl);
  }
  /* CTA principal un peu plus grand pour bien ressortir. */
  .hero__cta {
    padding: 1.05em 1.8em;
    font-size: var(--taille-base);
  }
  /* Accès rapides : cercle plat + label dessous. */
  .hero__acces {
    display: flex;
    align-items: center;
    gap: var(--esp-lg);
    margin-top: var(--esp-lg);
  }
  .hero__acces-sep {
    width: 1px;
    height: 2.6rem;
    background: var(--bordure);
  }
  .hero__acces-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    text-decoration: none;
    color: var(--couleur-texte);
  }
  .hero__acces-ico {
    display: grid;
    place-items: center;
    width: 3.6rem;
    height: 3.6rem;
    border-radius: 50%;
    background: var(--bleu-medium);
    color: var(--blanc);
    box-shadow: var(--ombre-md);
    transition: transform var(--transition-douce), background-color var(--transition-douce), box-shadow var(--transition-douce);
  }
  .hero__acces-lbl {
    font-size: var(--taille-sm);
    font-weight: var(--graisse-medium);
  }
  .hero__acces-item:hover .hero__acces-ico {
    transform: translateY(-2px);
    background: var(--bleu-profond);
    box-shadow: var(--ombre-lg);
  }

  @media (max-width: 760px) {
    .hero__bg {
      object-position: 60% center;
      /* Zoom + recadrage vertical : fait descendre l'enseigne/la façade
         dans la zone libre sous les boutons, loin du texte. */
      transform: scale(1.5);
      transform-origin: top center;
    }
    .hero__scrim {
      background: linear-gradient(
        165deg,
        rgba(255, 255, 255, 0.7) 0%,
        rgba(255, 255, 255, 0.5) 45%,
        rgba(255, 255, 255, 0.25) 100%
      );
    }
    .hero__inner {
      min-height: 100svh;
      /* Un peu plus d'écart avec le badge/burger flottants en haut. */
      padding-block: clamp(3.25rem, 7.5vh, 4.5rem) var(--esp-xl);
    }
    /* Tout le contenu du hero centré sur mobile. */
    .hero__contenu {
      max-width: 100%;
      text-align: center;
    }
    .hero__logo {
      /* Logo agrandi et rapproché du titre. */
      width: clamp(340px, 76vw, 460px);
      margin-inline: auto;
      margin-bottom: 0.25rem;
    }
    .hero__actions {
      justify-content: center;
    }
    .hero__cta {
      width: 100%;
    }
    .hero__acces {
      justify-content: center;
    }

    /* Statut déplacé en haut à droite, aligné avec le burger menu :
       date du jour + état + chevron pour ouvrir la popup des horaires. */
    .hero__statut {
      position: fixed;
      top: 1rem;
      right: 1rem;
      z-index: 200;
      margin: 0;
      gap: 0.5rem;
      height: 3rem;
      padding: 0 0.9rem 0 1rem;
      background: color-mix(in srgb, var(--blanc) 82%, transparent);
      backdrop-filter: saturate(160%) blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.7);
      border-radius: var(--rayon-pilule);
      box-shadow: var(--ombre-md);
      animation: none;
    }
    .hero__statut-date {
      display: inline;
      font-size: var(--taille-xs);
      font-weight: var(--graisse-medium);
      color: var(--couleur-texte-doux);
      white-space: nowrap;
    }
    .hero__statut-txt {
      flex-direction: row;
      gap: 0.4rem;
    }
    .hero__statut-etat {
      font-size: var(--taille-sm);
      white-space: nowrap;
    }
    .hero__statut-detail {
      display: none;
    }
    .hero__statut-chevron {
      display: inline-block;
      color: var(--slate-2);
      flex: none;
    }

    /* Voile plus léger = moins de contraste garanti par endroits (ex. sur le
       feuillage) : une ombre blanche douce protège la lisibilité du texte. */
    .hero__acces-lbl {
      text-shadow: 0 1px 4px rgba(255, 255, 255, 0.9), 0 1px 12px rgba(255, 255, 255, 0.6);
    }
  }

  /* --- Popup des horaires (dialog) --- */
  .modal-horaires {
    margin: auto;
    width: calc(100% - 2rem);
    max-width: 26rem;
    padding: 0;
    border: none;
    border-radius: var(--rayon-lg);
    box-shadow: var(--ombre-lg);
    color: var(--couleur-texte);
    background: var(--blanc);
  }
  .modal-horaires::backdrop {
    background: rgba(10, 46, 92, 0.45);
    backdrop-filter: blur(2px);
  }
  .modal-horaires__inner {
    position: relative;
    padding: var(--esp-xl) var(--esp-lg) var(--esp-lg);
  }
  .modal-horaires__close {
    position: absolute;
    top: var(--esp-sm);
    right: var(--esp-sm);
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border: none;
    border-radius: 50%;
    background: var(--bleu-clair-1);
    color: var(--bleu-profond);
    cursor: pointer;
    transition: background-color var(--transition-douce);
  }
  .modal-horaires__close:hover {
    background: var(--bleu-clair-3);
  }
  .modal-horaires__titre {
    font-size: var(--taille-md);
    margin-bottom: var(--esp-md);
  }
  .modal-horaires__jours {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--bordure);
    border-radius: var(--rayon-md);
    overflow: hidden;
  }
  .modal-horaires__jour {
    display: flex;
    justify-content: space-between;
    gap: var(--esp-md);
    padding: 0.6rem var(--esp-md);
  }
  .modal-horaires__jour + .modal-horaires__jour {
    border-top: 1px solid var(--bleu-clair-2);
  }
  .modal-horaires__jour dt {
    font-weight: var(--graisse-medium);
  }
  .modal-horaires__jour dd {
    color: var(--couleur-texte-doux);
    font-size: var(--taille-sm);
  }
  .modal-horaires__jour.est-ferme dd {
    color: var(--slate-2);
  }
  .modal-horaires__note {
    margin-top: var(--esp-sm);
    font-size: var(--taille-sm);
    color: var(--couleur-texte-doux);
  }
  .modal-horaires__garde {
    display: flex;
    align-items: center;
    gap: var(--esp-xs);
    margin-top: var(--esp-md);
    padding: var(--esp-sm) var(--esp-md);
    background: var(--bleu-clair-1);
    border-radius: var(--rayon-md);
    font-size: var(--taille-sm);
  }
  .modal-horaires__garde :global(svg) {
    color: var(--bleu-medium);
    flex: none;
  }
  .modal-horaires__garde strong {
    color: var(--bleu-medium);
  }
</style>
