---
/**
 * Hero plein écran (page d'arrivée) : photo de la façade en fond, logo, titre,
 * statut « Ouvert / Fermé » en direct et actions. Reste le HAUT de la page
 * unique (le bouton descend vers les sections) — pas une page-portail séparée,
 * pour préserver le référencement.
 */
import { Image } from 'astro:assets';
import facade from '../assets/facade-pharmacie.png';
import { hero, pharmacie, horaires, horairesNote, lienItineraire, logo } from '../data/site';
import Icone from './Icone.astro';

// Met les deux derniers mots du titre en accent doré italique (« avec soin »).
const motsTitre = hero.titre.trim().split(/\s+/);
const titreAccent = motsTitre.slice(-2).join(' ');
const titreDebut = motsTitre.slice(0, -2).join(' ');
---

<section class="hero" id="accueil">
  <Image
    src={facade}
    alt={`Façade de la ${pharmacie.nom}, au bord de mer à Cargèse au coucher du soleil`}
    class="hero__bg"
    widths={[640, 1024, 1400, 1659]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
  />
  <!-- Filtre bleuté léger + dégradé sombre en bas (lisibilité du texte). -->
  <div class="hero__tint" aria-hidden="true"></div>
  <div class="hero__scrim" aria-hidden="true"></div>

  <!-- Logo emblème, centré en haut. -->
  <img
    class="hero__logo"
    src={logo.srcTransparent}
    alt={`Logo ${pharmacie.nom}`}
    width={logo.largeur}
    height={logo.hauteur}
    decoding="async"
  />

  <div class="conteneur hero__inner">
    <div class="hero__contenu">
      <h1 class="hero__titre">
        {titreDebut} <span class="hero__titre-accent">{titreAccent}.</span>
      </h1>

      <div class="hero__actions">
        <a href="#services" class="hero__cta">Découvrir nos services</a>
      </div>

      <!-- Accès rapides : icône + label en ligne, sobres. -->
      <div class="hero__acces">
        <a
          href={`tel:${pharmacie.telephone.lien}`}
          class="hero__acces-item"
          aria-label={`Appeler la ${pharmacie.nom} au ${pharmacie.telephone.affichage}`}
        >
          <Icone nom="phone" taille={19} />
          <span>Appeler</span>
        </a>
        <span class="hero__acces-sep" aria-hidden="true"></span>
        <a
          href={lienItineraire}
          target="_blank"
          rel="noopener"
          class="hero__acces-item"
          aria-label={`Itinéraire vers la ${pharmacie.nom}`}
        >
          <Icone nom="route" taille={19} />
          <span>Itinéraire</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Statut d'ouverture, pastille flottante (→ ouvre la popup des horaires). -->
  <button class="hero__statut" data-hero-statut type="button">
    <span class="hero__statut-dot" aria-hidden="true"></span>
    <span class="hero__statut-etat" data-statut-etat>{hero.ouverture}</span>
    <span class="hero__statut-detail" data-statut-detail></span>
  </button>
</section>

<!-- Popup des horaires (dialog natif, ouvert au clic sur le statut). -->
<dialog class="modal-horaires" data-horaires-modal aria-label="Horaires d'ouverture">
  <div class="modal-horaires__inner">
    <button class="modal-horaires__close" data-close type="button" aria-label="Fermer">
      <Icone nom="close" taille={20} />
    </button>
    <h2 class="modal-horaires__titre">Horaires d'ouverture</h2>
    <dl class="modal-horaires__jours">
      {horaires.map((c) => (
        <div class:list={['modal-horaires__jour', { 'est-ferme': c.ferme }]}>
          <dt>{c.jour}</dt>
          <dd>{c.heures}</dd>
        </div>
      ))}
    </dl>
    <p class="modal-horaires__note">{horairesNote}</p>
    <p class="modal-horaires__garde">
      <Icone nom="shield" taille={18} />
      <span>Pharmacie de garde : <strong>{pharmacie.garde}</strong> (24h/24)</span>
    </p>
  </div>
</dialog>

<!-- Statut Ouvert / Fermé en direct + ouverture de la popup horaires. -->
<script define:vars={{ horaires }}>
  (function () {
    const el = document.querySelector('[data-hero-statut]');
    if (!el) return;

    const parse = (str) => {
      if (!str) return [];
      const t = [...str.matchAll(/(\d{1,2})\s*[h:]\s*(\d{0,2})/g)].map(
        (m) => parseInt(m[1], 10) * 60 + (m[2] ? parseInt(m[2], 10) : 0)
      );
      const r = [];
      for (let i = 0; i + 1 < t.length; i += 2) r.push([t[i], t[i + 1]]);
      return r;
    };

    const now = new Date();
    const dayIdx = (now.getDay() + 6) % 7;
    const mins = now.getHours() * 60 + now.getMinutes();
    const today = horaires[dayIdx];
    const ranges = today && !today.ferme ? parse(today.heures) : [];
    const open = ranges.some(([o, c]) => mins >= o && mins < c);

    el.classList.add(open ? 'is-open' : 'is-closed');
    el.querySelector('[data-statut-etat]').textContent = open ? 'Ouvert' : 'Fermé';

    // Formate des minutes en « 8h30 » (ou « 19h » si les minutes sont nulles).
    const fmt = (m) => {
      const h = Math.floor(m / 60);
      const mm = m % 60;
      return mm === 0 ? `${h}h` : `${h}h${String(mm).padStart(2, '0')}`;
    };

    // Détail le plus utile selon le statut : heure de fermeture si ouvert,
    // prochaine ouverture (aujourd'hui ou un autre jour) si fermé.
    const detail = el.querySelector('[data-statut-detail]');
    if (detail) {
      let texte = '';
      if (open) {
        const enCours = ranges.find(([o, c]) => mins >= o && mins < c);
        texte = `ferme à ${fmt(enCours[1])}`;
      } else {
        const prochaine = ranges.find(([o]) => mins < o);
        if (prochaine) {
          texte = `ouvre à ${fmt(prochaine[0])}`;
        } else {
          for (let i = 1; i <= 7; i++) {
            const j = horaires[(dayIdx + i) % 7];
            const r = j && !j.ferme ? parse(j.heures) : [];
            if (r.length) {
              texte = `ouvre ${j.jour.toLowerCase()} à ${fmt(r[0][0])}`;
              break;
            }
          }
        }
      }
      detail.textContent = texte ? `· ${texte}` : '';
    }

    // Ouverture / fermeture de la popup des horaires.
    const modal = document.querySelector('[data-horaires-modal]');
    if (modal) {
      el.addEventListener('click', () => modal.showModal());
      const closeBtn = modal.querySelector('[data-close]');
      if (closeBtn) closeBtn.addEventListener('click', () => modal.close());
      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.close();
      });
    }
  })();
</script>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    border-bottom: 1px solid var(--bordure);
  }

  /* Photo de fond, plein cadre. */
  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: -3;
  }
  /* Filtre bleuté léger, homogène, sur toute la photo. */
  .hero__tint {
    position: absolute;
    inset: 0;
    z-index: -2;
    background: linear-gradient(
      180deg,
      rgba(12, 42, 84, 0.30) 0%,
      rgba(10, 32, 66, 0.14) 40%,
      rgba(8, 24, 50, 0.22) 100%
    );
  }
  /* Dégradé sombre ancré en bas : lisibilité du texte blanc. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to top,
      rgba(6, 18, 38, 0.9) 0%,
      rgba(6, 18, 38, 0.6) 20%,
      rgba(6, 18, 38, 0.12) 42%,
      rgba(6, 18, 38, 0) 60%
    );
  }

  /* Logo emblème, grand et centré en haut, posé sur le ciel. */
  .hero__logo {
    position: absolute;
    top: clamp(3.5rem, 7vh, 5rem);
    left: 50%;
    transform: translateX(-50%);
    width: clamp(300px, 70vw, 460px);
    height: auto;
    z-index: 3;
    filter: drop-shadow(0 1px 2px rgba(255, 255, 255, 0.5))
      drop-shadow(0 3px 18px rgba(0, 0, 0, 0.35));
    /* Animation dédiée : préserve le translateX(-50%) de centrage
       (l'animation générique le remettrait à zéro → logo décalé à droite). */
    animation: apparition-logo 0.7s ease both;
  }
  @keyframes apparition-logo {
    from { opacity: 0; transform: translateX(-50%) translateY(10px); }
    to { opacity: 1; transform: translateX(-50%); }
  }

  /* Plein écran : contenu centré, ancré en bas (façon page d'accueil d'app). */
  .hero__inner {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    min-height: 100svh;
    padding-block: clamp(5rem, 12vh, 8rem) clamp(2.25rem, 6vh, 3.5rem);
  }
  .hero__contenu {
    max-width: 34rem;
    margin-inline: auto;
    text-align: center;
    color: var(--blanc);
  }
  .hero__contenu > * {
    animation: apparition 0.7s ease both;
  }
  .hero__contenu > *:nth-child(2) { animation-delay: 0.08s; }
  .hero__contenu > *:nth-child(3) { animation-delay: 0.16s; }
  @keyframes apparition {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: none; }
  }

  .hero__titre {
    font-size: clamp(2.5rem, 1.5rem + 4vw, 4.1rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.08;
    color: var(--blanc);
    text-wrap: balance;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.28);
  }
  /* « avec soin » en accent doré italique. */
  .hero__titre-accent {
    font-style: italic;
    color: var(--accent-or);
  }

  /* Statut « Ouvert / Fermé », pastille flottante en verre sombre. */
  .hero__statut {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 200;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.6rem;
    margin: 0;
    padding: 0.35rem 0.9rem;
    background: rgba(15, 25, 42, 0.5);
    backdrop-filter: saturate(160%) blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: var(--rayon-pilule);
    font-family: inherit;
    color: var(--blanc);
    cursor: pointer;
  }
  .hero__statut-dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: var(--accent-or);
    flex: none;
  }
  .hero__statut-etat {
    font-weight: var(--graisse-forte);
    font-size: var(--taille-sm);
    white-space: nowrap;
  }
  .hero__statut-detail {
    font-size: var(--taille-sm);
    color: rgba(255, 255, 255, 0.78);
    white-space: nowrap;
  }
  .hero__statut.is-open .hero__statut-dot {
    background: #4ade80;
  }

  .hero__actions {
    display: flex;
    justify-content: center;
    margin-top: clamp(1.5rem, 4vh, 2.4rem);
  }
  /* CTA principal en verre sombre (le doré est réservé au titre). */
  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 27rem;
    padding: 1.05em 1.8em;
    font-family: var(--police-titre);
    font-size: var(--taille-base);
    font-weight: var(--graisse-medium);
    color: var(--blanc);
    text-decoration: none;
    background: rgba(15, 25, 42, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: var(--rayon-md);
    backdrop-filter: saturate(160%) blur(12px);
    transition: background-color var(--transition-douce), transform var(--transition-douce);
  }
  .hero__cta:hover {
    background: rgba(26, 40, 64, 0.65);
    transform: translateY(-1px);
  }
  /* Accès rapides : icône + label en ligne, discrets, sous le CTA. */
  .hero__acces {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1.25rem, 5vw, 2rem);
    margin-top: clamp(1.1rem, 3vh, 1.6rem);
  }
  .hero__acces-sep {
    width: 1px;
    height: 1.1rem;
    background: rgba(255, 255, 255, 0.4);
  }
  .hero__acces-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--blanc);
    font-family: var(--police-titre);
    font-weight: var(--graisse-medium);
    font-size: var(--taille-sm);
    opacity: 0.92;
    transition: opacity var(--transition-douce);
  }
  .hero__acces-item:hover {
    opacity: 1;
  }

  @media (max-width: 760px) {
    .hero__bg {
      object-position: 60% center;
    }
    .hero__contenu {
      max-width: 100%;
    }
    .hero__cta {
      max-width: none;
    }
  }

  /* --- Popup des horaires (dialog) --- */
  .modal-horaires {
    margin: auto;
    width: calc(100% - 2rem);
    max-width: 26rem;
    padding: 0;
    border: none;
    border-radius: var(--rayon-lg);
    box-shadow: var(--ombre-lg);
    color: var(--couleur-texte);
    background: var(--blanc);
  }
  .modal-horaires::backdrop {
    background: rgba(10, 46, 92, 0.45);
    backdrop-filter: blur(2px);
  }
  .modal-horaires__inner {
    position: relative;
    padding: var(--esp-xl) var(--esp-lg) var(--esp-lg);
  }
  .modal-horaires__close {
    position: absolute;
    top: var(--esp-sm);
    right: var(--esp-sm);
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border: none;
    border-radius: 50%;
    background: var(--bleu-clair-1);
    color: var(--bleu-profond);
    cursor: pointer;
    transition: background-color var(--transition-douce);
  }
  .modal-horaires__close:hover {
    background: var(--bleu-clair-3);
  }
  .modal-horaires__titre {
    font-size: var(--taille-md);
    margin-bottom: var(--esp-md);
  }
  .modal-horaires__jours {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--bordure);
    border-radius: var(--rayon-md);
    overflow: hidden;
  }
  .modal-horaires__jour {
    display: flex;
    justify-content: space-between;
    gap: var(--esp-md);
    padding: 0.6rem var(--esp-md);
  }
  .modal-horaires__jour + .modal-horaires__jour {
    border-top: 1px solid var(--bleu-clair-2);
  }
  .modal-horaires__jour dt {
    font-weight: var(--graisse-medium);
  }
  .modal-horaires__jour dd {
    color: var(--couleur-texte-doux);
    font-size: var(--taille-sm);
  }
  .modal-horaires__jour.est-ferme dd {
    color: var(--slate-2);
  }
  .modal-horaires__note {
    margin-top: var(--esp-sm);
    font-size: var(--taille-sm);
    color: var(--couleur-texte-doux);
  }
  .modal-horaires__garde {
    display: flex;
    align-items: center;
    gap: var(--esp-xs);
    margin-top: var(--esp-md);
    padding: var(--esp-sm) var(--esp-md);
    background: var(--bleu-clair-1);
    border-radius: var(--rayon-md);
    font-size: var(--taille-sm);
  }
  .modal-horaires__garde :global(svg) {
    color: var(--bleu-medium);
    flex: none;
  }
  .modal-horaires__garde strong {
    color: var(--bleu-medium);
  }
</style>
