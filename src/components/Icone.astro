---
/**
 * Icônes SVG sobres, tracées avec `currentColor` (héritent de la couleur du texte).
 * Décoratives par défaut (aria-hidden) ; passez un `titre` pour les rendre parlantes.
 */
interface Props {
  nom: string;
  taille?: number;
  titre?: string;
  class?: string;
}

const { nom, taille = 24, titre, class: classe } = Astro.props;

// Chaque icône = contenu interne d'un <svg> 24×24, stroke currentColor.
const icones: Record<string, string> = {
  // Icônes Lucide (lucide.dev), tracé d'origine.
  phone:
    '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>',
  route:
    '<polygon points="12 2 19 21 12 17 5 21 12 2"/>',
  pin: '<path d="M12 21s6.5-5.6 6.5-11A6.5 6.5 0 0 0 5.5 10c0 5.4 6.5 11 6.5 11Z"/><circle cx="12" cy="10" r="2.4"/>',
  clock:
    '<circle cx="12" cy="12" r="8.5"/><path d="M12 7.5V12l3 2"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="m4 7 8 5.5L20 7"/>',
  clipboard:
    '<rect x="5" y="4.5" width="14" height="16" rx="2.5"/><path d="M9 4.5a3 3 0 0 1 6 0"/><path d="M8.5 11h7M8.5 15h5"/>',
  test: '<path d="M9 3.5h6M10 3.5v6.2L6.4 17a2.4 2.4 0 0 0 2.1 3.5h7a2.4 2.4 0 0 0 2.1-3.5L14 9.7V3.5"/><path d="M8.5 14.5h7"/>',
  leaf: '<path d="M5 19c0-8 6-13 14-13 0 8-5 14-13 14-1 0-1 0-1-1Z"/><path d="M5 19c3-4 6-6 10-8"/>',
  plant:
    '<path d="M12 21v-8"/><path d="M12 14C9 14 5.5 12 5.5 7 10 7 12 9.5 12 13"/><path d="M12 13c0-4 2-7 6.5-7C18.5 11 15 13 12 13Z"/>',
  cross:
    '<rect x="9.2" y="3.5" width="5.6" height="17" rx="1.6"/><rect x="3.5" y="9.2" width="17" height="5.6" rx="1.6"/>',
  shield:
    '<path d="M12 3.2 19 6v5c0 4.4-3 7.8-7 9.4-4-1.6-7-5-7-9.4V6l7-2.8Z"/><path d="m9 12 2 2 4-4"/>',
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  heart:
    '<path d="M12 20s-7-4.5-9.2-9A4.6 4.6 0 0 1 12 6.5 4.6 4.6 0 0 1 21.2 11C19 15.5 12 20 12 20Z"/>',
  image:
    '<rect x="3.5" y="4.5" width="17" height="15" rx="2.5"/><circle cx="9" cy="10" r="1.6"/><path d="m5 18 4.5-4.5a2 2 0 0 1 2.7-.1L19 19"/>',
  close: '<path d="M6 6l12 12M18 6 6 18"/>',
  menu: '<path d="M4 7h16M4 12h16M4 17h16"/>',
  chevron: '<path d="M6 9l6 6 6-6"/>',
};

const contenu = icones[nom] ?? '';
const parlante = Boolean(titre);
---

<svg
  viewBox="0 0 24 24"
  width={taille}
  height={taille}
  fill="none"
  stroke="currentColor"
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={classe}
  role={parlante ? 'img' : undefined}
  aria-label={parlante ? titre : undefined}
  aria-hidden={parlante ? undefined : 'true'}
  focusable="false"
  set:html={contenu}
/>
