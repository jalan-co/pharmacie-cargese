---
/**
 * Bandeau d'en-tête pour les pages intérieures (Services, Horaires).
 * Fond bleu clair, fil d'Ariane visuel léger via le surtitre.
 */
interface Props {
  surtitre: string;
  titre: string;
  intro?: string;
}
const { surtitre, titre, intro } = Astro.props;
---

<section class="entete-page">
  <div class="conteneur">
    <p class="entete-page__surtitre">{surtitre}</p>
    <h1 class="entete-page__titre">{titre}</h1>
    {intro && <p class="entete-page__intro">{intro}</p>}
  </div>
</section>

<style>
  .entete-page {
    background: var(--bleu-clair-1);
    border-bottom: 1px solid var(--bordure);
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }
  .entete-page__surtitre {
    font-size: var(--taille-sm);
    font-weight: var(--graisse-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bleu-medium);
    margin-bottom: var(--esp-xs);
  }
  .entete-page__intro {
    margin-top: var(--esp-md);
    max-width: var(--largeur-texte);
    color: var(--couleur-texte-doux);
    font-size: var(--taille-md);
  }
</style>
