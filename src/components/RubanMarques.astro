---
/**
 * Ruban de marques défilant horizontalement en boucle, sans JavaScript.
 * La liste est dupliquée pour un défilement continu (l'animation translate de
 * -50 % puis reboucle sans saut). Défilement mis en pause si l'utilisateur
 * préfère les animations réduites, et au survol / focus.
 */
import { marques } from '../data/site';

// On duplique la liste : la 2ᵉ moitié prend le relais quand la 1ʳᵉ sort.
const boucle = [...marques, ...marques];
---

<section class="ruban section" id="marques" aria-labelledby="ruban-titre">
  <div class="conteneur ruban__entete">
    <span class="surtitre">Nos marques</span>
    <h2 id="ruban-titre">Les marques que nous sélectionnons pour vous</h2>
  </div>

  <div class="ruban__masque">
    <ul class="ruban__piste" role="list">
      {
        boucle.map((marque, i) => (
          <li class="ruban__item" aria-hidden={i >= marques.length ? 'true' : undefined}>
            {marque}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .ruban {
    background: var(--bleu-clair-1);
    border-block: 1px solid var(--bordure);
  }
  .ruban__entete {
    text-align: center;
    margin-bottom: var(--esp-xl);
  }
  .ruban__entete .surtitre {
    color: var(--bleu-medium);
  }
  .ruban__entete h2 {
    max-width: 40rem;
    margin-inline: auto;
  }
  /* Le masque fait apparaître/disparaître le contenu en fondu sur les bords. */
  .ruban__masque {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .ruban__piste {
    display: flex;
    align-items: center;
    gap: var(--esp-2xl);
    width: max-content;
    padding-inline: var(--esp-xl);
    animation: defilement 32s linear infinite;
  }
  .ruban__masque:hover .ruban__piste,
  .ruban__masque:focus-within .ruban__piste {
    animation-play-state: paused;
  }
  .ruban__item {
    font-family: var(--police-titre);
    font-weight: var(--graisse-medium);
    font-size: var(--taille-md);
    color: var(--slate-2);
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  @keyframes defilement {
    from {
      transform: translateX(0);
    }
    to {
      /* La piste contient 2 copies : -50 % ramène pile au début. */
      transform: translateX(-50%);
    }
  }

  /* Accessibilité : pas d'animation si l'utilisateur la refuse.
     Le ruban devient alors une liste centrée qui peut défiler manuellement. */
  @media (prefers-reduced-motion: reduce) {
    .ruban__piste {
      animation: none;
      width: 100%;
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--esp-md) var(--esp-xl);
    }
    .ruban__item[aria-hidden='true'] {
      display: none;
    }
  }
</style>
