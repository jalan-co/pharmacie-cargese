---
/**
 * Menu « burger » flottant (pas d'en-tête pleine largeur) : posé en haut à
 * gauche, au-dessus du contenu, il reste accessible pendant le défilement.
 */
import { navigation } from '../data/site';
import Icone from './Icone.astro';
---

<details class="menu-flottant">
  <summary class="menu-flottant__btn" aria-label="Ouvrir le menu">
    <Icone nom="menu" taille={24} />
  </summary>
  <nav class="menu-flottant__panneau" aria-label="Navigation principale">
    <ul>
      {navigation.map((lien) => (
        <li><a href={lien.href}>{lien.libelle}</a></li>
      ))}
    </ul>
  </nav>
</details>

<script>
  const menu = document.querySelector('.menu-flottant');
  if (menu) {
    menu.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => menu.removeAttribute('open'))
    );
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') menu.removeAttribute('open');
    });
    document.addEventListener('click', (e) => {
      if (!menu.contains(e.target)) menu.removeAttribute('open');
    });
  }
</script>

<style>
  .menu-flottant {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 200;
  }
  .menu-flottant__btn {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 14px;
    background: rgba(15, 25, 42, 0.5);
    backdrop-filter: saturate(160%) blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.22);
    box-shadow: var(--ombre-md);
    color: var(--blanc);
    cursor: pointer;
    list-style: none;
    transition: transform var(--transition-douce), background-color var(--transition-douce);
  }
  .menu-flottant__btn:hover {
    background: rgba(26, 40, 64, 0.62);
  }
  .menu-flottant__btn::-webkit-details-marker {
    display: none;
  }
  .menu-flottant__btn:hover {
    transform: translateY(-1px);
  }
  .menu-flottant__panneau {
    position: absolute;
    top: calc(100% + 0.6rem);
    left: 0;
    min-width: 13rem;
    padding: var(--esp-xs);
    background: var(--blanc);
    border: 1px solid var(--bordure);
    border-radius: var(--rayon-md);
    box-shadow: var(--ombre-lg);
  }
  .menu-flottant__panneau ul {
    display: flex;
    flex-direction: column;
  }
  .menu-flottant__panneau a {
    display: block;
    padding: 0.6rem 0.9rem;
    border-radius: var(--rayon-sm);
    color: var(--couleur-texte);
    font-family: var(--police-titre);
    font-weight: var(--graisse-medium);
    font-size: var(--taille-sm);
    text-decoration: none;
    transition: background-color var(--transition-douce), color var(--transition-douce);
  }
  .menu-flottant__panneau a:hover {
    background: var(--bleu-clair-1);
    color: var(--bleu-medium);
  }
</style>
