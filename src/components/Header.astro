---
/**
 * En-tête : logo (dans une carte bordée), navigation par ancres et bouton
 * Appeler. Sticky en haut. Sur mobile, le bouton Appeler du header est relayé
 * par la barre fixe en bas d'écran (BarreAppelMobile).
 */
import { navigation, pharmacie, logo } from '../data/site';
import BoutonAppeler from './BoutonAppeler.astro';
---

<header class="entete">
  <div class="conteneur entete__inner">
    <a href="#accueil" class="entete__logo" aria-label={`${pharmacie.nom} — accueil`}>
      <img
        src={logo.src}
        alt={`Logo ${pharmacie.nom}`}
        width={Math.round((44 * logo.largeur) / logo.hauteur)}
        height={44}
        decoding="async"
      />
    </a>

    <nav class="entete__nav" aria-label="Navigation principale">
      <ul>
        {navigation.map((lien) => (
          <li><a href={lien.href}>{lien.libelle}</a></li>
        ))}
      </ul>
    </nav>

    <div class="entete__action">
      <BoutonAppeler variante="primaire" />
    </div>
  </div>
</header>

<style>
  .entete {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--blanc) 85%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--bordure);
  }
  .entete__inner {
    display: flex;
    align-items: center;
    gap: var(--esp-lg);
    min-height: 4.75rem;
  }
  /* Logo présenté dans une petite carte bordée, comme sur la maquette. */
  .entete__logo {
    display: inline-flex;
    align-items: center;
    margin-right: auto;
    padding: 0.35rem 0.6rem;
    background: var(--blanc);
    border: 1px solid var(--bordure);
    border-radius: var(--rayon-md);
    box-shadow: var(--ombre-sm);
  }
  .entete__logo img {
    height: 44px;
    width: auto;
  }

  .entete__nav ul {
    display: flex;
    align-items: center;
    gap: var(--esp-2xs);
  }
  .entete__nav a {
    display: inline-block;
    padding: 0.5rem 0.9rem;
    border-radius: var(--rayon-sm);
    font-family: var(--police-titre);
    font-size: var(--taille-sm);
    font-weight: var(--graisse-medium);
    color: var(--couleur-texte);
    text-decoration: none;
    transition: background-color var(--transition-douce), color var(--transition-douce);
  }
  .entete__nav a:hover {
    background: var(--bleu-clair-1);
    color: var(--bleu-medium);
  }

  @media (max-width: 780px) {
    .entete__inner {
      gap: var(--esp-md);
      min-height: 4rem;
    }
    .entete__action {
      display: none;
    }
    .entete__logo img {
      height: 38px;
    }
    .entete__nav a {
      padding: 0.45rem 0.55rem;
    }
  }
  @media (max-width: 420px) {
    .entete__nav a {
      font-size: var(--taille-xs);
      padding: 0.4rem 0.4rem;
    }
  }
</style>
