---
/**
 * Section « Horaires & accès » : horaires jour par jour, carte Google Maps,
 * itinéraire et rappel de la pharmacie de garde.
 */
import {
  pharmacie,
  horaires,
  horairesNote,
  lienItineraire,
  lienCarteEmbed,
} from '../data/site';
import Icone from './Icone.astro';
---

<section class="ha section" id="horaires" aria-labelledby="ha-titre">
  <div class="conteneur">
    <div class="ha__entete">
      <span class="surtitre">Horaires &amp; accès</span>
      <h2 id="ha-titre">Nous trouver et nous joindre</h2>
    </div>

    <div class="ha__grille">
      <!-- Colonne gauche : horaires + garde -->
      <div class="ha__col">
        <div class="ha__bloc">
          <h3 class="ha__bloc-titre">
            <Icone nom="clock" taille={20} /> Horaires d'ouverture
          </h3>
          <dl class="ha__jours">
            {horaires.map((c) => (
              <div class:list={['ha__jour', { 'ha__jour--ferme': c.ferme }]}>
                <dt>{c.jour}</dt>
                <dd>{c.heures}</dd>
              </div>
            ))}
          </dl>
          <p class="ha__note">{horairesNote}</p>
        </div>

        <div class="ha__garde">
          <span class="ha__garde-ico" aria-hidden="true"><Icone nom="shield" taille={22} /></span>
          <div class="ha__garde-txt">
            <strong>Pharmacie de garde</strong>
            <span>En dehors des horaires, composez le {pharmacie.garde}.</span>
          </div>
          <a href={`tel:${pharmacie.garde}`} class="btn btn--primaire ha__garde-btn">
            <Icone nom="phone" class="btn__icone" />
            <span>Appeler le {pharmacie.garde}</span>
          </a>
        </div>
      </div>

      <!-- Colonne droite : carte + adresse + itinéraire -->
      <div class="ha__col">
        <div class="ha__carte">
          <iframe
            title={`Carte de localisation de la ${pharmacie.nom}`}
            src={lienCarteEmbed}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>

        <div class="ha__adresse">
          <p>
            <Icone nom="pin" taille={20} />
            <span>{pharmacie.adresse.rue}, {pharmacie.adresse.complementRue}<br />{pharmacie.adresse.codePostal} {pharmacie.adresse.ville}</span>
          </p>
          <a href={lienItineraire} class="ha__maps-lien" target="_blank" rel="noopener">
            Ouvrir dans Google Maps
            <Icone nom="arrow" taille={16} />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ha {
    background: var(--bleu-clair-1);
    border-top: 1px solid var(--bordure);
  }
  .ha__entete {
    margin-bottom: var(--esp-xl);
  }
  .ha__grille {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--esp-xl);
    align-items: start;
  }
  .ha__col {
    display: flex;
    flex-direction: column;
    gap: var(--esp-lg);
  }

  .ha__bloc {
    background: var(--blanc);
    border: 1px solid var(--bordure);
    border-radius: var(--rayon-lg);
    padding: var(--esp-lg);
  }
  .ha__bloc-titre {
    display: flex;
    align-items: center;
    gap: var(--esp-xs);
    font-size: var(--taille-md);
    margin-bottom: var(--esp-md);
  }
  .ha__bloc-titre :global(svg) {
    color: var(--bleu-medium);
  }
  .ha__jours {
    display: flex;
    flex-direction: column;
  }
  .ha__jour {
    display: flex;
    justify-content: space-between;
    gap: var(--esp-md);
    padding: 0.7rem 0;
    border-top: 1px solid var(--bleu-clair-2);
  }
  .ha__jour:first-child {
    border-top: none;
  }
  .ha__jour dt {
    font-weight: var(--graisse-medium);
  }
  .ha__jour dd {
    color: var(--couleur-texte);
  }
  .ha__jour--ferme dd {
    color: var(--slate-2);
  }
  .ha__note {
    margin-top: var(--esp-md);
    font-size: var(--taille-sm);
    color: var(--couleur-texte-doux);
  }

  .ha__garde {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: var(--esp-sm) var(--esp-md);
    padding: var(--esp-lg);
    background: var(--bleu-profond);
    color: var(--blanc);
    border-radius: var(--rayon-lg);
  }
  .ha__garde-ico {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--rayon-md);
    background: rgba(255, 255, 255, 0.12);
    color: var(--blanc);
  }
  .ha__garde-txt strong {
    display: block;
  }
  .ha__garde-txt span {
    font-size: var(--taille-sm);
    color: var(--bleu-clair-3);
  }
  .ha__garde-btn {
    grid-column: 1 / -1;
    background: var(--blanc);
    color: var(--bleu-profond);
  }
  .ha__garde-btn:hover {
    background: var(--bleu-clair-1);
  }

  .ha__carte {
    border-radius: var(--rayon-lg);
    overflow: hidden;
    border: 1px solid var(--bordure);
    box-shadow: var(--ombre-sm);
    min-height: 20rem;
  }
  .ha__carte iframe {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 20rem;
    border: 0;
  }
  .ha__adresse {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--esp-md);
    padding: var(--esp-lg);
    background: var(--blanc);
    border: 1px solid var(--bordure);
    border-radius: var(--rayon-lg);
  }
  .ha__adresse p {
    display: flex;
    gap: var(--esp-sm);
    align-items: start;
  }
  .ha__adresse :global(svg) {
    color: var(--bleu-medium);
    flex: none;
    margin-top: 2px;
  }
  .ha__maps-lien {
    display: inline-flex;
    align-items: center;
    gap: var(--esp-2xs);
    font-weight: var(--graisse-medium);
    font-size: var(--taille-sm);
    color: var(--bleu-medium);
    text-decoration: none;
    white-space: nowrap;
  }
  .ha__maps-lien:hover {
    text-decoration: underline;
  }

  @media (max-width: 860px) {
    .ha__grille {
      grid-template-columns: 1fr;
    }
  }
</style>
