---
/**
 * Section « Horaires & accès » : horaires jour par jour, carte Google Maps,
 * itinéraire et rappel de la pharmacie de garde.
 */
import {
  pharmacie,
  horaires,
  horairesNote,
  lienItineraire,
  lienCarteEmbed,
} from '../data/site';
import Icone from './Icone.astro';
---

<section class="ha section" id="horaires" aria-labelledby="ha-titre">
  <div class="conteneur">
    <div class="ha__entete">
      <span class="surtitre">Horaires &amp; accès</span>
      <h2 id="ha-titre">Nous trouver et nous joindre</h2>
    </div>

    <div class="ha__grille">
      <!-- Colonne gauche : horaires + garde -->
      <div class="ha__col">
        <div class="ha__bloc">
          <h3 class="ha__bloc-titre">
            <Icone nom="clock" taille={20} /> Horaires d'ouverture
          </h3>
          <dl class="ha__jours">
            {horaires.map((c) => (
              <div class:list={['ha__jour', { 'ha__jour--ferme': c.ferme }]}>
                <dt>{c.jour}</dt>
                <dd>{c.heures}</dd>
              </div>
            ))}
          </dl>
          <p class="ha__note">{horairesNote}</p>

          <details class="ha__garde">
            <summary class="ha__garde-sum">
              <Icone nom="shield" taille={18} />
              <span>Pharmacie de garde</span>
              <Icone nom="chevron" taille={16} class="ha__garde-chevron" />
            </summary>
            <div class="ha__garde-contenu">
              <p>En dehors des horaires, composez le <strong>{pharmacie.garde}</strong> (24h/24).</p>
              <a href={`tel:${pharmacie.garde}`} class="btn btn--primaire ha__garde-btn">
                <Icone nom="phone" class="btn__icone" />
                <span>Appeler le {pharmacie.garde}</span>
              </a>
            </div>
          </details>
        </div>
      </div>

      <!-- Colonne droite : carte + adresse + itinéraire -->
      <div class="ha__col">
        <div class="ha__carte">
          <iframe
            title={`Carte de localisation de la ${pharmacie.nom}`}
            src={lienCarteEmbed}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>

        <div class="ha__adresse">
          <p>
            <Icone nom="pin" taille={20} />
            <span>{pharmacie.adresse.rue}, {pharmacie.adresse.complementRue}<br />{pharmacie.adresse.codePostal} {pharmacie.adresse.ville}</span>
          </p>
          <a href={lienItineraire} class="ha__maps-lien" target="_blank" rel="noopener">
            Ouvrir dans Google Maps
            <Icone nom="arrow" taille={16} />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ha {
    background: var(--bleu-clair-1);
    border-top: 1px solid var(--bordure);
  }
  .ha__entete {
    margin-bottom: var(--esp-xl);
  }
  .ha__grille {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--esp-xl);
    align-items: start;
  }
  .ha__col {
    display: flex;
    flex-direction: column;
    gap: var(--esp-lg);
  }

  .ha__bloc {
    background: var(--blanc);
    border: 1px solid var(--bordure);
    border-radius: var(--rayon-lg);
    padding: var(--esp-lg);
  }
  .ha__bloc-titre {
    display: flex;
    align-items: center;
    gap: var(--esp-xs);
    font-size: var(--taille-md);
    margin-bottom: var(--esp-md);
  }
  .ha__bloc-titre :global(svg) {
    color: var(--bleu-medium);
  }
  .ha__jours {
    display: flex;
    flex-direction: column;
  }
  .ha__jour {
    display: flex;
    justify-content: space-between;
    gap: var(--esp-md);
    padding: 0.7rem 0;
    border-top: 1px solid var(--bleu-clair-2);
  }
  .ha__jour:first-child {
    border-top: none;
  }
  .ha__jour dt {
    font-weight: var(--graisse-medium);
  }
  .ha__jour dd {
    color: var(--couleur-texte);
  }
  .ha__jour--ferme dd {
    color: var(--slate-2);
  }
  .ha__note {
    margin-top: var(--esp-md);
    font-size: var(--taille-sm);
    color: var(--couleur-texte-doux);
  }

  /* Garde en accordéon (plié par défaut) intégré au bloc horaires. */
  .ha__garde {
    margin-top: var(--esp-md);
    border-top: 1px solid var(--bordure);
    padding-top: var(--esp-sm);
  }
  .ha__garde-sum {
    display: flex;
    align-items: center;
    gap: var(--esp-xs);
    padding: var(--esp-xs) 0;
    font-weight: var(--graisse-medium);
    color: var(--couleur-texte);
    cursor: pointer;
    list-style: none;
  }
  .ha__garde-sum::-webkit-details-marker {
    display: none;
  }
  .ha__garde-sum :global(svg:first-child) {
    color: var(--bleu-medium);
    flex: none;
  }
  .ha__garde-chevron {
    margin-left: auto;
    color: var(--slate-2);
    transition: transform var(--transition-douce);
  }
  .ha__garde[open] .ha__garde-chevron {
    transform: rotate(180deg);
  }
  .ha__garde-contenu {
    padding: var(--esp-xs) 0 var(--esp-2xs);
  }
  .ha__garde-contenu p {
    font-size: var(--taille-sm);
    color: var(--couleur-texte-doux);
    margin-bottom: var(--esp-sm);
  }
  .ha__garde-contenu strong {
    color: var(--bleu-medium);
    letter-spacing: 0.02em;
  }
  .ha__garde-btn {
    width: 100%;
  }

  .ha__carte {
    border-radius: var(--rayon-lg);
    overflow: hidden;
    border: 1px solid var(--bordure);
    box-shadow: var(--ombre-sm);
    min-height: 20rem;
  }
  .ha__carte iframe {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 20rem;
    border: 0;
  }
  .ha__adresse {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--esp-md);
    padding: var(--esp-lg);
    background: var(--blanc);
    border: 1px solid var(--bordure);
    border-radius: var(--rayon-lg);
  }
  .ha__adresse p {
    display: flex;
    gap: var(--esp-sm);
    align-items: start;
  }
  .ha__adresse :global(svg) {
    color: var(--bleu-medium);
    flex: none;
    margin-top: 2px;
  }
  .ha__maps-lien {
    display: inline-flex;
    align-items: center;
    gap: var(--esp-2xs);
    font-weight: var(--graisse-medium);
    font-size: var(--taille-sm);
    color: var(--bleu-medium);
    text-decoration: none;
    white-space: nowrap;
  }
  .ha__maps-lien:hover {
    text-decoration: underline;
  }

  @media (max-width: 860px) {
    .ha__grille {
      grid-template-columns: 1fr;
    }
  }
</style>
