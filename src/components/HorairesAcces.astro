---
/**
 * Section « Horaires & accès » : horaires jour par jour, carte Google Maps,
 * itinéraire et rappel de la pharmacie de garde.
 */
import {
  pharmacie,
  horaires,
  horairesNote,
  lienItineraire,
  lienCarteEmbed,
} from '../data/site';
import Icone from './Icone.astro';
---

<section class="ha section" id="horaires" aria-labelledby="ha-titre">
  <div class="conteneur">
    <div class="ha__entete">
      <span class="surtitre">Horaires &amp; accès</span>
      <h2 id="ha-titre">Nous trouver et nous joindre</h2>
    </div>

    <div class="ha__grille">
      <!-- Colonne gauche : horaires + garde -->
      <div class="ha__col">
        <div class="ha__bloc">
          <details class="ha__horaires">
            <summary class="ha__horaires-sum">
              <Icone nom="clock" taille={20} />
              <span class="ha__sum-titre">Horaires d'ouverture</span>
              <span class="ha__statut" data-ha-statut>
                <span class="ha__statut-dot" aria-hidden="true"></span>
                <span class="ha__statut-etat" data-ha-etat></span>
              </span>
              <Icone nom="chevron" taille={16} class="ha__horaires-chevron" />
            </summary>
            <dl class="ha__jours">
              {horaires.map((c) => (
                <div class:list={['ha__jour', { 'ha__jour--ferme': c.ferme }]}>
                  <dt>{c.jour}</dt>
                  <dd>{c.heures}</dd>
                </div>
              ))}
            </dl>
            <p class="ha__note">{horairesNote}</p>

            <!-- Pharmacie de garde : dans le dépliant (masquée quand plié). -->
            <div class="ha__garde">
              <div class="ha__garde-txt">
                <span class="ha__garde-titre">
                  <Icone nom="shield" taille={18} /> Pharmacie de garde
                </span>
                <p>En dehors des horaires, composez le <strong>{pharmacie.garde}</strong> (24h/24).</p>
              </div>
              <a href={`tel:${pharmacie.garde}`} class="btn btn--primaire ha__garde-btn">
                <Icone nom="phone" class="btn__icone" />
                <span>Appeler le {pharmacie.garde}</span>
              </a>
            </div>
          </details>
        </div>
      </div>

      <!-- Colonne droite : carte + adresse + itinéraire -->
      <div class="ha__col">
        <div class="ha__carte">
          <iframe
            title={`Carte de localisation de la ${pharmacie.nom}`}
            src={lienCarteEmbed}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>

        <div class="ha__adresse">
          <p>
            <Icone nom="pin" taille={20} />
            <span>{pharmacie.adresse.rue}, {pharmacie.adresse.complementRue}<br />{pharmacie.adresse.codePostal} {pharmacie.adresse.ville}</span>
          </p>
          <a href={lienItineraire} class="ha__maps-lien" target="_blank" rel="noopener">
            Ouvrir dans Google Maps
            <Icone nom="arrow" taille={16} />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Statut Ouvert / Fermé en direct sur la barre des horaires. -->
<script define:vars={{ horaires }}>
  (function () {
    const el = document.querySelector('[data-ha-statut]');
    if (!el) return;

    const parse = (str) => {
      if (!str) return [];
      const t = [...str.matchAll(/(\d{1,2})\s*[h:]\s*(\d{0,2})/g)].map(
        (m) => parseInt(m[1], 10) * 60 + (m[2] ? parseInt(m[2], 10) : 0)
      );
      const r = [];
      for (let i = 0; i + 1 < t.length; i += 2) r.push([t[i], t[i + 1]]);
      return r;
    };

    const now = new Date();
    const dayIdx = (now.getDay() + 6) % 7;
    const mins = now.getHours() * 60 + now.getMinutes();
    const today = horaires[dayIdx];
    const ranges = today && !today.ferme ? parse(today.heures) : [];
    const open = ranges.some(([o, c]) => mins >= o && mins < c);

    el.classList.add(open ? 'is-open' : 'is-closed');
    el.querySelector('[data-ha-etat]').textContent = open ? 'Ouvert' : 'Fermé';
  })();
</script>

<style>
  .ha {
    background: var(--bleu-clair-1);
    border-top: 1px solid var(--bordure);
  }
  .ha__entete {
    margin-bottom: var(--esp-xl);
  }
  .ha__grille {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--esp-xl);
    align-items: start;
  }
  .ha__col {
    display: flex;
    flex-direction: column;
    gap: var(--esp-lg);
  }

  .ha__bloc {
    background: var(--blanc);
    border: 1px solid var(--bordure);
    border-radius: var(--rayon-lg);
    padding: var(--esp-lg);
  }
  /* Horaires en accordéon (plié par défaut). */
  .ha__horaires-sum {
    display: flex;
    align-items: center;
    gap: var(--esp-xs);
    font-family: var(--police-titre);
    font-weight: var(--graisse-forte);
    font-size: var(--taille-md);
    color: var(--couleur-texte);
    cursor: pointer;
    list-style: none;
  }
  .ha__horaires-sum::-webkit-details-marker {
    display: none;
  }
  .ha__horaires-sum > :global(svg:first-child) {
    color: var(--bleu-medium);
    flex: none;
  }
  .ha__sum-titre {
    margin-right: var(--esp-sm);
  }
  /* Statut live (Ouvert/Fermé) sur la barre repliée, comme le hero. */
  .ha__statut {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-left: auto;
    font-size: var(--taille-sm);
  }
  .ha__statut-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--statut-ferme);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--statut-ferme) 18%, transparent);
    flex: none;
  }
  .ha__statut-etat {
    font-weight: var(--graisse-medium);
    color: var(--statut-ferme);
  }
  .ha__statut.is-open .ha__statut-dot {
    background: var(--statut-ouvert);
  }
  .ha__statut.is-open .ha__statut-etat {
    color: var(--statut-ouvert);
  }
  .ha__horaires-chevron {
    margin-left: var(--esp-sm);
    color: var(--slate-2);
    transition: transform var(--transition-douce);
  }
  .ha__horaires[open] .ha__horaires-chevron {
    transform: rotate(180deg);
  }
  .ha__jours {
    display: flex;
    flex-direction: column;
    margin-top: var(--esp-md);
  }
  .ha__jour {
    display: flex;
    justify-content: space-between;
    gap: var(--esp-md);
    padding: 0.7rem 0;
    border-top: 1px solid var(--bleu-clair-2);
  }
  .ha__jour:first-child {
    border-top: none;
  }
  .ha__jour dt {
    font-weight: var(--graisse-medium);
  }
  .ha__jour dd {
    color: var(--couleur-texte);
  }
  .ha__jour--ferme dd {
    color: var(--slate-2);
  }
  .ha__note {
    margin-top: var(--esp-md);
    font-size: var(--taille-sm);
    color: var(--couleur-texte-doux);
  }

  /* Garde : simple (non pliable), sous les horaires. */
  .ha__garde {
    margin-top: var(--esp-lg);
    padding-top: var(--esp-lg);
    border-top: 1px solid var(--bordure);
  }
  .ha__garde-titre {
    display: inline-flex;
    align-items: center;
    gap: var(--esp-xs);
    font-weight: var(--graisse-forte);
    color: var(--couleur-texte);
  }
  .ha__garde-titre :global(svg) {
    color: var(--bleu-medium);
    flex: none;
  }
  .ha__garde-txt p {
    margin-top: var(--esp-2xs);
    font-size: var(--taille-sm);
    color: var(--couleur-texte-doux);
  }
  .ha__garde-txt strong {
    color: var(--bleu-medium);
    letter-spacing: 0.02em;
  }
  .ha__garde-btn {
    width: 100%;
    margin-top: var(--esp-md);
  }

  .ha__carte {
    border-radius: var(--rayon-lg);
    overflow: hidden;
    border: 1px solid var(--bordure);
    box-shadow: var(--ombre-sm);
    min-height: 20rem;
  }
  .ha__carte iframe {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 20rem;
    border: 0;
  }
  .ha__adresse {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--esp-md);
    padding: var(--esp-lg);
    background: var(--blanc);
    border: 1px solid var(--bordure);
    border-radius: var(--rayon-lg);
  }
  .ha__adresse p {
    display: flex;
    gap: var(--esp-sm);
    align-items: start;
  }
  .ha__adresse :global(svg) {
    color: var(--bleu-medium);
    flex: none;
    margin-top: 2px;
  }
  .ha__maps-lien {
    display: inline-flex;
    align-items: center;
    gap: var(--esp-2xs);
    font-weight: var(--graisse-medium);
    font-size: var(--taille-sm);
    color: var(--bleu-medium);
    text-decoration: none;
    white-space: nowrap;
  }
  .ha__maps-lien:hover {
    text-decoration: underline;
  }

  @media (max-width: 860px) {
    .ha__grille {
      grid-template-columns: 1fr;
    }
  }
</style>
