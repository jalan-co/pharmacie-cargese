---
/**
 * Section « À propos » : présentation de la pharmacie de village (texte
 * éditorial, pas d'argumentaire commercial) + vidéo d'une patiente souriante,
 * pour mettre le patient au cœur du discours.
 */
import { apropos } from '../data/site';
---

<section class="apropos section" id="apropos" aria-labelledby="apropos-titre">
  <div class="conteneur apropos__inner">
    <div class="apropos__texte">
      <span class="surtitre">{apropos.surtitre}</span>
      <h2 id="apropos-titre">{apropos.titre}</h2>
      {apropos.paragraphes.map((p) => <p class="apropos__p">{p}</p>)}
    </div>

    <div class="apropos__visuel">
      <!--
        Image animée (WebP animé) plutôt qu'une <video> : se lance vraiment
        toute seule sur mobile (pas de bouton play imposé par le navigateur).
      -->
      <img
        class="apropos__media"
        src="/apropos-poster.webp"
        data-anime="/apropos.webp"
        width="420"
        height="560"
        loading="lazy"
        decoding="async"
        alt="Sourire d'une patiente accueillie à l'officine"
      />
    </div>
  </div>
</section>

<script>
  // Respecte prefers-reduced-motion : n'affiche l'image animée que si l'utilisateur n'a pas demandé de réduire les animations.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('.apropos__media[data-anime]').forEach((img) => {
      img.src = img.dataset.anime;
    });
  }
</script>

<style>
  .apropos__inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: var(--esp-2xl);
  }
  .apropos__texte h2 {
    margin-top: var(--esp-2xs);
  }
  .apropos__p {
    margin-top: var(--esp-md);
    color: var(--couleur-texte-doux);
    max-width: var(--largeur-texte);
  }
  .apropos__p:first-of-type {
    color: var(--couleur-texte);
    font-size: var(--taille-md);
  }

  .apropos__media {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: var(--rayon-lg);
    box-shadow: var(--ombre-md);
    background: var(--bleu-clair-1);
  }

  @media (max-width: 860px) {
    .apropos__inner {
      grid-template-columns: 1fr;
      gap: var(--esp-xl);
    }
    .apropos__visuel {
      max-width: 22rem;
      margin-inline: auto;
    }
  }
</style>
