---
/**
 * Pied de page : présentation, adresse, contact, appel à l'action.
 */
import { pharmacie, logo } from '../data/site';
import Icone from './Icone.astro';
import BoutonAppeler from './BoutonAppeler.astro';

const annee = 2026; // Site statique : année figée à la mise en ligne.
---

<footer class="pied">
  <div class="conteneur pied__inner">
    <div class="pied__marque">
      <span class="pied__logo">
        <img
          src={logo.src}
          alt={`Logo ${pharmacie.nom}`}
          width={Math.round((44 * logo.largeur) / logo.hauteur)}
          height={44}
          decoding="async"
        />
      </span>
      <p class="pied__desc">
        Votre pharmacie de proximité en Corse, au cœur du village de Cargèse.
        Conseil, prévention et accompagnement, six jours sur sept.
      </p>
      <p class="pied__titulaire">
        Pharmacien titulaire : <strong>{pharmacie.pharmacien}</strong><br />
        {pharmacie.pharmacienTitre}
      </p>
    </div>

    <div class="pied__col">
      <h2 class="pied__titre">Adresse</h2>
      <address class="pied__adresse">
        {pharmacie.adresse.rue}<br />
        {pharmacie.adresse.complementRue}<br />
        {pharmacie.adresse.codePostal} {pharmacie.adresse.ville}
      </address>
    </div>

    <div class="pied__col">
      <h2 class="pied__titre">Contact</h2>
      <ul class="pied__contact">
        <li>
          <Icone nom="phone" taille={18} />
          <a href={`tel:${pharmacie.telephone.lien}`}>{pharmacie.telephone.affichage}</a>
        </li>
        <li>
          <Icone nom="mail" taille={18} />
          <a href={`mailto:${pharmacie.email}`}>{pharmacie.email}</a>
        </li>
        <li class="pied__garde">
          <Icone nom="shield" taille={18} />
          <span>Garde : <strong>{pharmacie.garde}</strong></span>
        </li>
      </ul>
    </div>

    <div class="pied__col">
      <h2 class="pied__titre">Un besoin&nbsp;?</h2>
      <BoutonAppeler variante="primaire" afficherNumero={true} class="pied__cta" />
    </div>
  </div>

  <div class="pied__bas">
    <div class="conteneur pied__bas-inner">
      <p>© {annee} {pharmacie.nom}</p>
      <p>Site vitrine — informations non contractuelles</p>
    </div>
  </div>
</footer>

<style>
  .pied {
    background: var(--bleu-profond);
    color: var(--bleu-clair-2);
    margin-top: 0;
  }
  .pied__inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.2fr 1fr;
    gap: var(--esp-xl);
    padding-block: var(--esp-2xl);
  }
  .pied__logo {
    display: inline-flex;
    padding: 0.35rem 0.6rem;
    background: var(--blanc);
    border-radius: var(--rayon-md);
  }
  .pied__logo img {
    height: 44px;
    width: auto;
  }
  .pied__desc {
    margin-top: var(--esp-md);
    max-width: 24rem;
    font-size: var(--taille-sm);
    color: var(--bleu-clair-3);
  }
  .pied__titulaire {
    margin-top: var(--esp-md);
    font-size: var(--taille-sm);
    color: var(--bleu-clair-3);
  }
  .pied__titulaire strong {
    color: var(--blanc);
    font-weight: var(--graisse-medium);
  }
  .pied__titre {
    font-size: var(--taille-xs);
    font-weight: var(--graisse-forte);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--blanc);
    margin-bottom: var(--esp-md);
  }
  .pied__adresse {
    font-style: normal;
    font-size: var(--taille-sm);
    color: var(--bleu-clair-2);
    line-height: 1.9;
  }
  .pied__contact {
    display: flex;
    flex-direction: column;
    gap: var(--esp-sm);
    font-size: var(--taille-sm);
  }
  .pied__contact li {
    display: flex;
    align-items: center;
    gap: var(--esp-sm);
  }
  .pied__contact :global(svg) {
    color: var(--bleu-clair-3);
    flex: none;
  }
  .pied a {
    color: var(--bleu-clair-2);
    text-decoration: none;
  }
  .pied a:hover {
    color: var(--blanc);
    text-decoration: underline;
  }
  .pied__garde strong {
    color: var(--blanc);
    letter-spacing: 0.04em;
  }

  .pied__bas {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }
  .pied__bas-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--esp-xs);
    padding-block: var(--esp-lg);
    font-size: var(--taille-xs);
    color: var(--slate-2);
  }

  @media (max-width: 860px) {
    .pied__inner {
      grid-template-columns: 1fr 1fr;
    }
    .pied__marque {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 480px) {
    .pied__inner {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 780px) {
    .pied__bas {
      padding-bottom: 4.75rem; /* place pour la barre d'appel mobile */
    }
  }
</style>
