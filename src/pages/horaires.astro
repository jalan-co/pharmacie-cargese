---
/**
 * Page « Horaires & accès » : carte Google Maps, horaires, adresse, garde 3237.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import EntetePage from '../components/EntetePage.astro';
import HorairesAcces from '../components/HorairesAcces.astro';
import { seo } from '../data/site';

const meta = seo['/horaires'];
---

<BaseLayout title={meta.title} description={meta.description}>
  <EntetePage
    surtitre="Horaires & accès"
    titre="Nous trouver et nous joindre"
    intro="Retrouvez nos horaires d'ouverture, notre adresse et l'itinéraire vers l'officine, au quartier Saint-Jean à Cargèse."
  />

  <HorairesAcces avecCarte={true} niveauTitre={2} />
</BaseLayout>
