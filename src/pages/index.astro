---
/**
 * Page unique (landing) :
 * hero, chiffres clés, services (photos + texte superposé), pourquoi nous,
 * marques, horaires.
 */
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import BlocStats from '../components/BlocStats.astro';
import Icone from '../components/Icone.astro';
import PourquoiNous from '../components/PourquoiNous.astro';
import RubanMarques from '../components/RubanMarques.astro';
import HorairesAcces from '../components/HorairesAcces.astro';
import { services, seo } from '../data/site';

// Photos des services (propres, sans texte : le texte est du vrai HTML posé
// par-dessus → éditable, lisible sur mobile, lu par Google).
import imgBilan from '../assets/services/service-bilan.webp';
import imgTests from '../assets/services/service-tests.webp';
import imgMicro from '../assets/services/service-micronutrition.webp';
import imgPhyto from '../assets/services/service-phyto.webp';
const serviceImages = [imgBilan, imgTests, imgMicro, imgPhyto];
---

<BaseLayout title={seo.title} description={seo.description}>
  <Hero />
  <BlocStats />

  <section class="services section" id="services" aria-labelledby="services-titre">
    <div class="conteneur">
      <div class="services__entete">
        <span class="surtitre">Nos services</span>
        <h2 id="services-titre">Un accompagnement complet, au-delà de l'ordonnance</h2>
      </div>

      <ul class="services__grille" role="list">
        {services.map((service, i) => (
          <li class="services__carte">
            {serviceImages[i] ? (
              <Image
                src={serviceImages[i]}
                alt={service.titre}
                class="services__img"
                widths={[500, 768]}
                sizes="(max-width: 700px) 100vw, 45vw"
                loading="lazy"
              />
            ) : (
              <div class="services__img services__img--vide"></div>
            )}
            <div class="services__overlay">
              <span class="services__ico" aria-hidden="true">
                <Icone nom={service.icone} taille={24} />
              </span>
              <h3 class="services__titre">{service.titre}</h3>
              <p class="services__desc">{service.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <PourquoiNous />
  <RubanMarques />
  <HorairesAcces />
</BaseLayout>

<style>
  .services__entete {
    max-width: 46rem;
    margin-bottom: var(--esp-xl);
  }
  .services__entete h2 {
    margin-top: var(--esp-2xs);
  }

  .services__grille {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--esp-lg);
  }

  /* Carte : photo en fond, texte superposé sur un dégradé bleu. */
  .services__carte {
    position: relative;
    aspect-ratio: 3 / 2;
    border-radius: var(--rayon-lg);
    overflow: hidden;
    box-shadow: var(--ombre-sm);
    transition: transform var(--transition-douce), box-shadow var(--transition-douce);
  }
  .services__carte:hover {
    transform: translateY(-4px);
    box-shadow: var(--ombre-md);
  }
  .services__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .services__img--vide {
    background: linear-gradient(135deg, var(--bleu-medium), var(--bleu-profond));
  }
  .services__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--esp-2xs);
    padding: var(--esp-lg);
    color: var(--blanc);
    background: linear-gradient(
      to top,
      rgba(10, 46, 92, 0.92) 0%,
      rgba(10, 46, 92, 0.5) 35%,
      rgba(10, 46, 92, 0) 68%
    );
  }
  .services__ico {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    margin-bottom: var(--esp-xs);
    border: 1.5px solid rgba(255, 255, 255, 0.6);
    border-radius: 50%;
    color: var(--blanc);
  }
  .services__titre {
    color: var(--blanc);
    font-size: var(--taille-md);
  }
  .services__desc {
    color: rgba(255, 255, 255, 0.9);
    font-size: var(--taille-sm);
    max-width: 26rem;
  }

  @media (max-width: 700px) {
    .services__grille {
      grid-template-columns: 1fr;
    }
  }
</style>
