---
/**
 * Page unique (landing) reproduisant la maquette validée :
 * hero, chiffres clés, services, pourquoi nous, marques, horaires & accès.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import BlocStats from '../components/BlocStats.astro';
import CarteService from '../components/CarteService.astro';
import PourquoiNous from '../components/PourquoiNous.astro';
import RubanMarques from '../components/RubanMarques.astro';
import HorairesAcces from '../components/HorairesAcces.astro';
import { services, seo, lienItineraire } from '../data/site';
---

<BaseLayout title={seo.title} description={seo.description}>
  <Hero />
  <BlocStats />

  <section class="services section" id="services" aria-labelledby="services-titre">
    <div class="conteneur">
      <div class="services__entete">
        <div>
          <span class="surtitre">Nos services</span>
          <h2 id="services-titre">Un accompagnement complet, au-delà de l'ordonnance</h2>
        </div>
        <a href="#horaires" class="services__lien">Tous les services</a>
      </div>

      <ul class="services__grille" role="list">
        {services.map((service) => (
          <li><CarteService service={service} niveauTitre={3} /></li>
        ))}
      </ul>
    </div>
  </section>

  <PourquoiNous />
  <RubanMarques />
  <HorairesAcces />
</BaseLayout>

<style>
  .services__entete {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--esp-md);
    margin-bottom: var(--esp-xl);
  }
  .services__entete h2 {
    margin-top: var(--esp-2xs);
    max-width: 30rem;
  }
  .services__lien {
    font-weight: var(--graisse-medium);
    font-size: var(--taille-sm);
    color: var(--bleu-medium);
    text-decoration: none;
    white-space: nowrap;
  }
  .services__lien:hover {
    text-decoration: underline;
  }
  /* Grille résiliente : s'adapte à n'importe quel nombre de services,
     les cartes se répartissent et se centrent (jamais de carte isolée étirée). */
  .services__grille {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--esp-lg);
  }
  .services__grille > li {
    flex: 1 1 240px;
    max-width: 320px;
  }
  @media (max-width: 540px) {
    .services__grille > li {
      max-width: none;
    }
  }
</style>
